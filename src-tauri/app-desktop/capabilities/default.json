{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for Z-Source desktop",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "sql:default",
    "sql:allow-load",
    "sql:allow-execute",
    "sql:allow-select",
    "sql:allow-close",
    "store:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://api.football-data.org/*" },
        { "url": "https://api.odds-api.io/*" },
        { "url": "https://api.actionnetwork.com/*" },
        { "url": "https://statsapi.mlb.com/*" }
      ]
    }
  ]
}
